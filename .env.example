# Copy to .env for local development only. Never put real secrets in release artifacts.

HUBBLEOPS_ENV=dev
HUBBLEOPS_AUTH_ENABLED=true
HUBBLEOPS_DEV_AUTH_BYPASS=true
HUBBLEOPS_METRICS_PUBLIC=true
HUBBLEOPS_CAPTURE_MODE=fingerprint
HUBBLEOPS_ALLOW_RAW_CAPTURE_IN_PROD=false
HUBBLEOPS_ALLOW_RAW_CAPTURE_IN_PROD_NOTE=
HUBBLEOPS_REQUIRE_RECEIPT_FOR_BLOCK=true
HUBBLEOPS_ENFORCE_WITHOUT_RECEIPT=false

HUBBLEOPS_SERVER_HOST=0.0.0.0
HUBBLEOPS_SERVER_PORT=8080

HUBBLEOPS_POSTGRES_HOST=localhost
HUBBLEOPS_POSTGRES_PORT=5432
HUBBLEOPS_POSTGRES_USER=hubbleops
HUBBLEOPS_POSTGRES_PASSWORD=replace-with-local-postgres-password
HUBBLEOPS_POSTGRES_DBNAME=hubbleops
HUBBLEOPS_POSTGRES_SSLMODE=disable

HUBBLEOPS_REDIS_HOST=localhost
HUBBLEOPS_REDIS_PORT=6379
HUBBLEOPS_REDIS_PASSWORD=
HUBBLEOPS_REDIS_DB=0

HUBBLEOPS_WAL_DIR=data/wal
HUBBLEOPS_WAL_SYNC_MODE=batch

HUBBLEOPS_LOOP_ENABLED=true
HUBBLEOPS_LOOP_ACTION=shadow
HUBBLEOPS_LOOP_REQUIRE_SESSION_FOR_BLOCK=true

HUBBLEOPS_BUDGET_DAILY_SOFT_USD=0
HUBBLEOPS_BUDGET_DAILY_HARD_USD=0
HUBBLEOPS_BUDGET_RESERVE_PER_REQUEST_USD=0.50

# Optional local-only provider and receipt settings.
GOOGLE_API_KEY=replace-with-local-google-key
GEMINI_API_KEY=replace-with-local-gemini-key
HUBBLEOPS_RECEIPT_SIGNING_SECRET=replace-with-local-receipt-signing-secret
HUBBLEOPS_RECEIPT_KEY_ID=local-dev

# Production gate receipt signing uses external KMS instead of the local secret.
# Supported signers: none, local (dev only), aws-kms. gcp-kms and vault-transit
# are planned but not yet implemented; configuring them is rejected at startup.
# HUBBLEOPS_RECEIPT_SIGNER=aws-kms
# HUBBLEOPS_RECEIPT_KMS_KEY_ID=arn:aws:kms:us-east-1:123456789012:key/...
# HUBBLEOPS_RECEIPT_KMS_REGION=us-east-1
# HUBBLEOPS_RECEIPT_KEY_ID=prod-2026-07
